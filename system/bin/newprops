#!/system/bin/sh

MODDIR="/data/adb/modules/xkatrina_snstv_prps"

if [ ! -d "$MODDIR" ]; then
    echo "Module directory not found!"
    exit 1
fi

PROPS_LIST="$MODDIR/props_list.txt"
CUSTOM_PROPS="$MODDIR/custom_props.txt"

if [ ! -f "$PROPS_LIST" ]; then
    echo "File props_list.txt not found!"
    exit 1
fi

# Pilih satu baris secara acak, optimasi dengan shuf
if command -v shuf >/dev/null 2>&1; then
    SELECTED_PROP=$(shuf -n 1 "$PROPS_LIST")
else
    LINES=$(wc -l < "$PROPS_LIST")
    if [ "$LINES" -eq 0 ]; then
        echo "props_list.txt is empty!"
        exit 1
    fi
    RANDOM_LINE=$(( ($RANDOM % $LINES) + 1 ))
    SELECTED_PROP=$(sed -n "${RANDOM_LINE}p" "$PROPS_LIST")
fi

if [ -z "$SELECTED_PROP" ]; then
    echo "Failed to select a prop."
    exit 1
fi

# Ekstrak data dari baris yang dipilih (Format: BRAND|MODEL|DEVICE|FINGERPRINT)
BRAND=$(echo "$SELECTED_PROP" | cut -d'|' -f1)
MODEL=$(echo "$SELECTED_PROP" | cut -d'|' -f2)
DEVICE=$(echo "$SELECTED_PROP" | cut -d'|' -f3)
FINGERPRINT=$(echo "$SELECTED_PROP" | cut -d'|' -f4)

# Buat UTC date timestamp acak di masa lalu (baru-baru ini)
CURRENT_TS=$(date +"%s")
# Random 1-60 days ago
RANDOM_DAYS_AGO=$(( ($RANDOM % 60) + 1 ))
RANDOM_SECONDS_AGO=$(( RANDOM_DAYS_AGO * 86400 ))
TIMESTAMP=$(( CURRENT_TS - RANDOM_SECONDS_AGO ))
DATE_STR=$(date -u -d "@$TIMESTAMP" 2>/dev/null || date)

# Ekstrak OS_VER, ID, dan INCREMENTAL dari Fingerprint
OS_VER=$(echo "$FINGERPRINT" | cut -d':' -f2 | cut -d'/' -f1)
BUILD_ID=$(echo "$FINGERPRINT" | cut -d'/' -f4)
INCREMENTAL=$(echo "$FINGERPRINT" | cut -d'/' -f5 | cut -d':' -f1)

# Generate Random Android ID (16 hex chars)
NEW_ANDROID_ID=$(tr -dc 'a-f0-9' < /dev/urandom | head -c 16)

# Generate Random Serial Number (10 alphanumeric chars)
NEW_SERIAL=$(tr -dc 'A-Z0-9' < /dev/urandom | head -c 10)

echo "Generating new props for: $BRAND $MODEL ($DEVICE) | Android $OS_VER"

# Simpan Android ID ke file untuk dieksekusi service.sh setelah boot
echo "$NEW_ANDROID_ID" > "/data/local/tmp/new_android_id.txt"
echo "Saved new Settings.Secure.ANDROID_ID ($NEW_ANDROID_ID) to be applied at boot"

# Buat file custom_props.txt baru dengan format key=value untuk Zygisk module
cat <<EOF > "$CUSTOM_PROPS"
# Auto-generated by newprops
# Brand: $BRAND
# Model: $MODEL
# Device: $DEVICE
# Android: $OS_VER

# Serial Number
ro.serialno=$NEW_SERIAL

ro.bootimage.build.date=$DATE_STR
ro.bootimage.build.date.utc=$TIMESTAMP
ro.bootimage.build.fingerprint=$FINGERPRINT
ro.bootimage.build.id=$BUILD_ID
ro.bootimage.build.version.incremental=$INCREMENTAL
ro.bootimage.build.version.release=$OS_VER
ro.bootloader=$INCREMENTAL
ro.build.date=$DATE_STR
ro.build.date.utc=$TIMESTAMP
ro.build.description=$DEVICE-user $OS_VER $BUILD_ID $INCREMENTAL release-keys
ro.build.displayid=$BUILD_ID.$INCREMENTAL
ro.build.fingerprint=$FINGERPRINT
ro.build.id=$BUILD_ID
ro.build.product=$DEVICE
ro.build.version.incremental=$INCREMENTAL
ro.build.version.release=$OS_VER
ro.hardware=$DEVICE
ro.lineage.device=$DEVICE
ro.matrixx.device=$DEVICE
ro.odm.build.date=$DATE_STR
ro.odm.build.date.utc=$TIMESTAMP
ro.odm.build.fingerprint=$FINGERPRINT
ro.odm.build.id=$BUILD_ID
ro.odm.build.version.incremental=$INCREMENTAL
ro.odm.build.version.release=$OS_VER
ro.odm_dlkm.build.fingerprint=$FINGERPRINT
ro.product.board=$DEVICE
ro.product.bootimage.brand=$BRAND
ro.product.bootimage.device=$DEVICE
ro.product.bootimage.manufacturer=$BRAND
ro.product.bootimage.model=$MODEL
ro.product.bootimage.name=$DEVICE
ro.product.brand=$BRAND
ro.product.build.date=$DATE_STR
ro.product.build.date.utc=$TIMESTAMP
ro.product.build.fingerprint=$FINGERPRINT
ro.product.build.id=$BUILD_ID
ro.product.build.version.incremental=$INCREMENTAL
ro.product.build.version.release=$OS_VER
ro.product.device=$DEVICE
ro.product.manufacturer=$BRAND
ro.product.model=$MODEL
ro.product.name=$DEVICE
ro.product.odm.brand=$BRAND
ro.product.odm.device=$DEVICE
ro.product.odm.manufacturer=$BRAND
ro.product.odm.model=$MODEL
ro.product.odm.name=$DEVICE
ro.product.odm_dlkm.brand=$BRAND
ro.product.odm_dlkm.device=$DEVICE
ro.product.odm_dlkm.model=$MODEL
ro.product.product.brand=$BRAND
ro.product.product.device=$DEVICE
ro.product.product.manufacturer=$BRAND
ro.product.product.model=$MODEL
ro.product.product.name=$DEVICE
ro.product.system.brand=$BRAND
ro.product.system.device=$DEVICE
ro.product.system.manufacturer=$BRAND
ro.product.system.model=$MODEL
ro.product.system.name=$DEVICE
ro.product.system_ext.brand=$BRAND
ro.product.system_ext.device=$DEVICE
ro.product.system_ext.manufacturer=$BRAND
ro.product.system_ext.model=$MODEL
ro.product.system_ext.name=$DEVICE
ro.product.vendor.brand=$BRAND
ro.product.vendor.device=$DEVICE
ro.product.vendor.manufacturer=$BRAND
ro.product.vendor.model=$MODEL
ro.product.vendor.name=$DEVICE
ro.product.vendor_dlkm.brand=$BRAND
ro.product.vendor_dlkm.device=$DEVICE
ro.product.vendor_dlkm.manufacturer=$BRAND
ro.product.vendor_dlkm.model=$MODEL
ro.product.vendor_dlkm.name=$DEVICE
ro.system.build.date=$DATE_STR
ro.system.build.date.utc=$TIMESTAMP
ro.system.build.fingerprint=$FINGERPRINT
ro.system.build.id=$BUILD_ID
ro.system.build.version.incremental=$INCREMENTAL
ro.system.build.version.release=$OS_VER
ro.system_ext.build.date=$DATE_STR
ro.system_ext.build.date.utc=$TIMESTAMP
ro.system_ext.build.fingerprint=$FINGERPRINT
ro.system_ext.build.id=$BUILD_ID
ro.system_ext.build.version.incremental=$INCREMENTAL
ro.system_ext.build.version.release=$OS_VER
ro.vendor.build.date=$DATE_STR
ro.vendor.build.date.utc=$TIMESTAMP
ro.vendor.build.fingerprint=$FINGERPRINT
ro.vendor.build.id=$BUILD_ID
ro.vendor.build.version.incremental=$INCREMENTAL
ro.vendor.build.version.release=$OS_VER
ro.vendor_dlkm.build.date=$DATE_STR
ro.vendor_dlkm.build.date.utc=$TIMESTAMP
ro.vendor_dlkm.build.fingerprint=$FINGERPRINT
ro.vendor_dlkm.build.id=$BUILD_ID
ro.vendor_dlkm.build.version.incremental=$INCREMENTAL
ro.vendor_dlkm.build.version.release=$OS_VER
EOF

echo "Successfully generated new props."
echo "Please REBOOT your device to apply the new fingerprint correctly."
