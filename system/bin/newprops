#!/system/bin/sh

MODDIR="/data/adb/modules/xkatrina_snstv_prps"

if [ ! -d "$MODDIR" ]; then
    echo "Module directory not found!"
    exit 1
fi

PROPS_LIST="$MODDIR/props_list.txt"
CUSTOM_PROPS="$MODDIR/custom_props.txt"

if [ ! -f "$PROPS_LIST" ]; then
    echo "File props_list.txt not found!"
    exit 1
fi

# Dapatkan jumlah baris di props_list.txt
LINES=$(wc -l < "$PROPS_LIST")

if [ "$LINES" -eq 0 ]; then
    echo "props_list.txt is empty!"
    exit 1
fi

# Pilih satu baris secara acak
RANDOM_LINE=$(( ($RANDOM % $LINES) + 1 ))
SELECTED_PROP=$(sed -n "${RANDOM_LINE}p" "$PROPS_LIST")

# Ekstrak data dari baris yang dipilih (Format: BRAND|MODEL|DEVICE|FINGERPRINT)
BRAND=$(echo "$SELECTED_PROP" | cut -d'|' -f1)
MODEL=$(echo "$SELECTED_PROP" | cut -d'|' -f2)
DEVICE=$(echo "$SELECTED_PROP" | cut -d'|' -f3)
FINGERPRINT=$(echo "$SELECTED_PROP" | cut -d'|' -f4)

# Buat UTC date timestamp acak di masa lalu (baru-baru ini)
CURRENT_TS=$(date +"%s")
# Random 1-60 days ago
RANDOM_DAYS_AGO=$(( ($RANDOM % 60) + 1 ))
RANDOM_SECONDS_AGO=$(( RANDOM_DAYS_AGO * 86400 ))
TIMESTAMP=$(( CURRENT_TS - RANDOM_SECONDS_AGO ))
DATE_STR=$(date -u -d "@$TIMESTAMP" 2>/dev/null || date)

# Ekstrak OS_VER, ID, dan INCREMENTAL dari Fingerprint
OS_VER=$(echo "$FINGERPRINT" | cut -d':' -f2 | cut -d'/' -f1)
BUILD_ID=$(echo "$FINGERPRINT" | cut -d'/' -f4)
INCREMENTAL=$(echo "$FINGERPRINT" | cut -d'/' -f5 | cut -d':' -f1)

# Generate Random Android ID (16 hex chars)
NEW_ANDROID_ID=$(tr -dc 'a-f0-9' < /dev/urandom | head -c 16)

echo "Generating new props for: $BRAND $MODEL ($DEVICE) | Android $OS_VER"

# Terapkan Android ID baru langsung
settings put secure android_id "$NEW_ANDROID_ID" >/dev/null 2>&1
echo "Applied new Settings.Secure.ANDROID_ID: $NEW_ANDROID_ID"

# Save new Android ID to be applied on next boot
echo "$NEW_ANDROID_ID" > "$MODDIR/android_id.txt"

# Buat file custom_props.txt baru
cat <<EOF > "$CUSTOM_PROPS"
# Auto-generated by newprops
# Brand: $BRAND
# Model: $MODEL
# Device: $DEVICE
# Android: $OS_VER

check_resetprop ro.bootimage.build.date "$DATE_STR"
check_resetprop ro.bootimage.build.date.utc $TIMESTAMP
check_resetprop ro.bootimage.build.fingerprint $FINGERPRINT
check_resetprop ro.bootimage.build.id $BUILD_ID
check_resetprop ro.bootimage.build.version.incremental $INCREMENTAL
check_resetprop ro.bootimage.build.version.release $OS_VER
check_resetprop ro.bootloader $INCREMENTAL
check_resetprop ro.build.date "$DATE_STR"
check_resetprop ro.build.date.utc $TIMESTAMP
check_resetprop ro.build.description "$DEVICE-user $OS_VER $BUILD_ID $INCREMENTAL release-keys"
check_resetprop ro.build.displayid $BUILD_ID.$INCREMENTAL
check_resetprop ro.build.fingerprint $FINGERPRINT
check_resetprop ro.build.id $BUILD_ID
check_resetprop ro.build.product $DEVICE
check_resetprop ro.build.version.incremental $INCREMENTAL
check_resetprop ro.build.version.release $OS_VER
check_resetprop ro.hardware $DEVICE
check_resetprop ro.lineage.device $DEVICE
check_resetprop ro.matrixx.device $DEVICE
check_resetprop ro.odm.build.date "$DATE_STR"
check_resetprop ro.odm.build.date.utc $TIMESTAMP
check_resetprop ro.odm.build.fingerprint $FINGERPRINT
check_resetprop ro.odm.build.id $BUILD_ID
check_resetprop ro.odm.build.version.incremental $INCREMENTAL
check_resetprop ro.odm.build.version.release $OS_VER
check_resetprop ro.odm_dlkm.build.fingerprint $FINGERPRINT
check_resetprop ro.product.board $DEVICE
check_resetprop ro.product.bootimage.brand $BRAND
check_resetprop ro.product.bootimage.device $DEVICE
check_resetprop ro.product.bootimage.manufacturer $BRAND
check_resetprop ro.product.bootimage.model "$MODEL"
check_resetprop ro.product.bootimage.name $DEVICE
check_resetprop ro.product.brand $BRAND
check_resetprop ro.product.build.date "$DATE_STR"
check_resetprop ro.product.build.date.utc $TIMESTAMP
check_resetprop ro.product.build.fingerprint $FINGERPRINT
check_resetprop ro.product.build.id $BUILD_ID
check_resetprop ro.product.build.version.incremental $INCREMENTAL
check_resetprop ro.product.build.version.release $OS_VER
check_resetprop ro.product.device $DEVICE
check_resetprop ro.product.manufacturer $BRAND
check_resetprop ro.product.model "$MODEL"
check_resetprop ro.product.name $DEVICE
check_resetprop ro.product.odm.brand $BRAND
check_resetprop ro.product.odm.device $DEVICE
check_resetprop ro.product.odm.manufacturer $BRAND
check_resetprop ro.product.odm.model "$MODEL"
check_resetprop ro.product.odm.name $DEVICE
check_resetprop ro.product.odm_dlkm.brand $BRAND
check_resetprop ro.product.odm_dlkm.device $DEVICE
check_resetprop ro.product.odm_dlkm.model "$MODEL"
check_resetprop ro.product.product.brand $BRAND
check_resetprop ro.product.product.device $DEVICE
check_resetprop ro.product.product.manufacturer $BRAND
check_resetprop ro.product.product.model "$MODEL"
check_resetprop ro.product.product.name $DEVICE
check_resetprop ro.product.system.brand $BRAND
check_resetprop ro.product.system.device $DEVICE
check_resetprop ro.product.system.manufacturer $BRAND
check_resetprop ro.product.system.model "$MODEL"
check_resetprop ro.product.system.name $DEVICE
check_resetprop ro.product.system_ext.brand $BRAND
check_resetprop ro.product.system_ext.device $DEVICE
check_resetprop ro.product.system_ext.manufacturer $BRAND
check_resetprop ro.product.system_ext.model "$MODEL"
check_resetprop ro.product.system_ext.name $DEVICE
check_resetprop ro.product.vendor.brand $BRAND
check_resetprop ro.product.vendor.device $DEVICE
check_resetprop ro.product.vendor.manufacturer $BRAND
check_resetprop ro.product.vendor.model "$MODEL"
check_resetprop ro.product.vendor.name $DEVICE
check_resetprop ro.product.vendor_dlkm.brand $BRAND
check_resetprop ro.product.vendor_dlkm.device $DEVICE
check_resetprop ro.product.vendor_dlkm.manufacturer $BRAND
check_resetprop ro.product.vendor_dlkm.model "$MODEL"
check_resetprop ro.product.vendor_dlkm.name $DEVICE
check_resetprop ro.system.build.date "$DATE_STR"
check_resetprop ro.system.build.date.utc $TIMESTAMP
check_resetprop ro.system.build.fingerprint $FINGERPRINT
check_resetprop ro.system.build.id $BUILD_ID
check_resetprop ro.system.build.version.incremental $INCREMENTAL
check_resetprop ro.system.build.version.release $OS_VER
check_resetprop ro.system_ext.build.date "$DATE_STR"
check_resetprop ro.system_ext.build.date.utc $TIMESTAMP
check_resetprop ro.system_ext.build.fingerprint $FINGERPRINT
check_resetprop ro.system_ext.build.id $BUILD_ID
check_resetprop ro.system_ext.build.version.incremental $INCREMENTAL
check_resetprop ro.system_ext.build.version.release $OS_VER
check_resetprop ro.vendor.build.date "$DATE_STR"
check_resetprop ro.vendor.build.date.utc $TIMESTAMP
check_resetprop ro.vendor.build.fingerprint $FINGERPRINT
check_resetprop ro.vendor.build.id $BUILD_ID
check_resetprop ro.vendor.build.version.incremental $INCREMENTAL
check_resetprop ro.vendor.build.version.release $OS_VER
check_resetprop ro.vendor_dlkm.build.date "$DATE_STR"
check_resetprop ro.vendor_dlkm.build.date.utc $TIMESTAMP
check_resetprop ro.vendor_dlkm.build.fingerprint $FINGERPRINT
check_resetprop ro.vendor_dlkm.build.id $BUILD_ID
check_resetprop ro.vendor_dlkm.build.version.incremental $INCREMENTAL
check_resetprop ro.vendor_dlkm.build.version.release $OS_VER
EOF

echo "Successfully generated new props."
echo "Please REBOOT your device to apply the new fingerprint correctly."
