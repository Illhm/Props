#!/system/bin/sh

# PropSpoof Command Line Tool

MODDIR="/data/adb/modules/dynamic_prop_spoofer"
PROFILES_LIST="$MODDIR/common/profiles.list"
CURRENT_PROFILE_FILE="$MODDIR/current_profile.txt"

if [ ! -d "$MODDIR" ]; then
    echo "Error: Module is not installed or enabled."
    exit 1
fi

show_help() {
    echo "Usage: propspoof [COMMAND]"
    echo ""
    echo "Commands:"
    echo "  status       Show the currently active profile."
    echo "  randomize    Immediately apply a random profile from the list."
    echo "  reload       Re-apply the current profile properties."
    echo "  next         Force selection of a new random profile for the next boot."
    echo "  list         Show available profiles."
    echo ""
    echo "Ensure you run this tool as root (su -c propspoof <command>)."
}

if [ "$(id -u)" -ne 0 ]; then
    echo "Error: This tool must be run as root."
    exit 1
fi

case "$1" in
    status)
        if [ -f "$CURRENT_PROFILE_FILE" ]; then
            echo "Current Profile Data:"
            cat "$CURRENT_PROFILE_FILE"
        else
            echo "No profile data found. Device might not have rebooted after install."
        fi
        ;;
    randomize)
        echo "Selecting and applying a new random profile..."
        NEXT_PROFILE=$(grep -v "^#" "$PROFILES_LIST" | shuf -n 1)
        if [ -n "$NEXT_PROFILE" ]; then
            echo "$NEXT_PROFILE" > "$CURRENT_PROFILE_FILE"
            # Re-run post-fs-data logic
            sh "$MODDIR/post-fs-data.sh"
            echo "Profile applied successfully."
        else
            echo "Error: Could not find profiles."
        fi
        ;;
    reload)
        echo "Reloading current profile properties..."
        sh "$MODDIR/post-fs-data.sh"
        echo "Properties reloaded."
        ;;
    next)
        echo "Preparing new random profile for next boot..."
        if [ -f "$CURRENT_PROFILE_FILE" ]; then
            CURRENT_DATA=$(cat "$CURRENT_PROFILE_FILE")
            NEXT_PROFILE=$(grep -v "^#" "$PROFILES_LIST" | grep -vF "$CURRENT_DATA" | shuf -n 1)
        else
            NEXT_PROFILE=$(grep -v "^#" "$PROFILES_LIST" | shuf -n 1)
        fi

        if [ -n "$NEXT_PROFILE" ]; then
            echo "$NEXT_PROFILE" > "$CURRENT_PROFILE_FILE"
            echo "Next profile set. Please reboot to apply."
        else
            echo "Error: Could not set next profile."
        fi
        ;;
    list)
        echo "Available profiles in $PROFILES_LIST:"
        grep -v "^#" "$PROFILES_LIST" | awk -F'|' '{print "- " $1 " " $3}'
        ;;
    *)
        show_help
        ;;
esac
